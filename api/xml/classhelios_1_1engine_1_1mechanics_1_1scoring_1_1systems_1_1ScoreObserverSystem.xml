</simplesect>
<simplesect kind="see"><para><ref refid="classhelios_1_1engine_1_1mechanics_1_1scoring_1_1ScorePoolManager" kindref="compound">ScorePoolManager</ref> </para>
</simplesect>
</para>
    </detaileddescription>
