        <name>flushCommandQueue</name>
        <qualifiedname>helios::engine::runtime::messaging::command::TypedCommandBuffer::flushCommandQueue</qualifiedname>
        <param>
          <type><ref refid="classhelios_1_1engine_1_1runtime_1_1world_1_1GameWorld" kindref="compound">GameWorld</ref> &amp;</type>
          <declname>gameWorld</declname>
        </param>
