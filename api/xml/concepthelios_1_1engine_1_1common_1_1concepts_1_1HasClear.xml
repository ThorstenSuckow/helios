    <initializer>template&lt;typename T&gt;
concept <ref refid="concepthelios_1_1engine_1_1common_1_1concepts_1_1HasClear" kindref="compound">helios::engine::common::concepts::HasClear</ref> =  requires(T&amp; t) {
        {t.clear() } -&gt; std::same_as&lt;void&gt;;
