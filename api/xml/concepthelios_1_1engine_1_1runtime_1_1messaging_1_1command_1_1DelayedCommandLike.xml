    <initializer>template&lt;typename Cmd&gt;
concept <ref refid="concepthelios_1_1engine_1_1runtime_1_1messaging_1_1command_1_1DelayedCommandLike" kindref="compound">helios::engine::runtime::messaging::command::DelayedCommandLike</ref> =  requires(Cmd const&amp; c) {
