      <memberdef kind="typedef" id="namespacehelios_1_1ecs_1_1types_1acf27c982c01d422a7605616c407ac7b0" prot="public" static="no">
        <type>uint32_t</type>
        <definition>using helios::ecs::types::EntityId =  uint32_t</definition>
        <argsstring></argsstring>
        <name>EntityId</name>
        <qualifiedname>helios::ecs::types::EntityId</qualifiedname>
        <briefdescription>
<para>Unique identifier for an entity within an EntityPool. </para>
        </briefdescription>
        <detaileddescription>
<para>Used as the index into the sparse array of an EntityPool. Combined with a <ref refid="namespacehelios_1_1ecs_1_1types_1a58cc516088b7b594d813b712c9337c8a" kindref="member">VersionId</ref> in an <ref refid="structhelios_1_1ecs_1_1types_1_1EntityHandle" kindref="compound">EntityHandle</ref>, it enables safe entity references that detect stale handles after entity removal.</para>
<para><simplesect kind="see"><para><ref refid="structhelios_1_1ecs_1_1types_1_1EntityHandle" kindref="compound">EntityHandle</ref> </para>
</simplesect>
<simplesect kind="see"><para><ref refid="namespacehelios_1_1ecs_1_1types_1a58cc516088b7b594d813b712c9337c8a" kindref="member">VersionId</ref> </para>
</simplesect>
<simplesect kind="see"><para>EntityPool </para>
</simplesect>
</para>
        </detaileddescription>
